{
  "name": "accounting-system-desktop",
  "version": "1.0.0",
  "description": "Professional Accounting System",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "check-backend": "node -e \"require('./src/main/backendClient').checkBackendHealth().then((r)=>console.log(JSON.stringify(r,null,2)))\""
  },
  "build": {
    "appId": "com.accountingsystem.app",
    "productName": "Accounting System",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "electron": "latest",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "accounting-system-monorepo": "file:..",
    "better-sqlite3": "^12.5.0",
    "pdf-lib": "^1.17.1"
  }
}
